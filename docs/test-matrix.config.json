      "`../test-matrix/syncmatrix/syncmatrix_test.go` (`TestSyncIncludesStaticRefsForNonTaggedRequirements`)"
    ]
  },
  "parsers": {
    ".go": {
      "kind": "go"
    },
    ".swift": {
